GEMINI_API_KEY=

# Must be a Moonshot platform API key from platform.moonshot.cn.
# Kimi CLI/session credentials are a separate product and do not work here.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Optional when using OpenAI API-key connectors.
# ChatGPT OAuth uses the local codex app-server session instead.
OPENAI_API_KEY=

# Optional local state overrides for testing or headless runs.
MAF_STATE_DIR=
MAF_CREDENTIAL_STORE_BACKEND=
MAF_CREDENTIAL_STORE_FILE=

# Set to 1 only when you want live-provider smoke tests.
RUN_LIVE_PROVIDER_TESTS=0

# Set to 1 only when you want the optional benchmark integration test.
RUN_BENCHMARK_TESTS=0
