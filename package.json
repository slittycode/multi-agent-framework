{
  "name": "multi-agent-framework",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build src/cli/main.ts --outdir dist --target bun",
    "start": "bun run src/cli/main.ts",
    "verify:offline": "bun run typecheck && bun test && bun run build",
    "verify:live": "bun run scripts/verify-live.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@google/genai": "1.44.0",
    "ajv": "8.18.0",
    "openai": "6.25.0"
  }
}
