{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://multi-agent-framework.local/schemas/domain-adapter.schema.json",
  "title": "Domain Adapter",
  "type": "object",
  "required": ["id", "name", "version", "agents", "rounds", "synthesisAgentId"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent" }
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/round" }
    },
    "synthesisAgentId": { "type": "string", "minLength": 1 },
    "orchestrator": { "$ref": "#/$defs/orchestratorConfigPartial" },
    "inputSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runIntro": { "type": "string" },
        "synthesisInstructions": { "type": "string" }
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["id", "name", "role", "persona", "systemPrompt"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "persona": { "type": "string", "minLength": 1 },
        "systemPrompt": { "type": "string", "minLength": 1 },
        "objective": { "type": "string" },
        "llm": { "$ref": "#/$defs/agentLLMConfig" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "agentLLMConfig": {
      "type": "object",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "temperature": { "type": "number" },
        "maxTokens": { "type": "number", "minimum": 1 },
        "topP": { "type": "number" },
        "timeoutMs": { "type": "number", "minimum": 1 },
        "providerOptions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "round": {
      "type": "object",
      "required": ["id", "name", "phases"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "phases": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/roundPhase" }
        }
      }
    },
    "roundPhase": {
      "type": "object",
      "required": ["id", "name", "instructions", "turnOrder"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "instructions": { "type": "string", "minLength": 1 },
        "turnOrder": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "maxTurnsPerAgent": { "type": "number", "minimum": 1 },
        "executionMode": {
          "type": "string",
          "enum": ["sequential", "fanout"]
        },
        "visibilityPolicy": {
          "type": "object",
          "required": ["participants"],
          "additionalProperties": false,
          "properties": {
            "participants": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "orchestratorConfigPartial": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "executionMode": { "type": "string", "enum": ["sequential"] },
        "failFast": { "type": "boolean" },
        "judge": { "$ref": "#/$defs/judgeConfig" },
        "contextPolicy": { "$ref": "#/$defs/contextPolicyConfig" },
        "phaseJudge": { "$ref": "#/$defs/phaseJudgeConfig" },
        "qualityGate": { "$ref": "#/$defs/qualityGateConfig" },
        "citations": { "$ref": "#/$defs/citationConfig" },
        "retry": {
          "type": "object",
          "required": ["attempts", "backoffMs"],
          "additionalProperties": false,
          "properties": {
            "attempts": { "type": "number", "minimum": 1 },
            "backoffMs": { "type": "number", "minimum": 0 }
          }
        },
        "synthesis": {
          "type": "object",
          "required": ["agentId", "trigger"],
          "additionalProperties": false,
          "properties": {
            "agentId": { "type": "string", "minLength": 1 },
            "trigger": { "type": "string", "enum": ["after_all_rounds"] }
          }
        },
        "transcript": {
          "type": "object",
          "required": ["persistToFile", "outputDir", "format"],
          "additionalProperties": false,
          "properties": {
            "persistToFile": { "type": "boolean" },
            "outputDir": { "type": "string", "minLength": 1 },
            "format": { "type": "string", "enum": ["json", "jsonl"] }
          }
        },
        "cli": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "showTimestamps": { "type": "boolean" },
            "showUsage": { "type": "boolean" },
            "colorize": { "type": "boolean" }
          }
        }
      }
    },
    "judgeConfig": {
      "type": "object",
      "required": ["agentId"],
      "additionalProperties": false,
      "properties": {
        "agentId": { "type": "string", "minLength": 1 },
        "promptTemplate": { "type": "string" }
      }
    },
    "contextPolicyConfig": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["full", "round_plus_recent"] },
        "recentMessageCount": { "type": "number", "minimum": 1 },
        "includePhaseSummaries": { "type": "boolean" }
      }
    },
    "phaseJudgeConfig": {
      "type": "object",
      "required": ["enabled", "cadence", "agentId"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "cadence": { "type": "string", "enum": ["after_each_phase"] },
        "agentId": { "type": "string", "minLength": 1 },
        "promptTemplate": { "type": "string" }
      }
    },
    "qualityGateConfig": {
      "type": "object",
      "required": ["enabled", "threshold"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "threshold": { "type": "number", "minimum": 0, "maximum": 100 },
        "recordInTranscriptMetadata": { "type": "boolean" }
      }
    },
    "citationConfig": {
      "type": "object",
      "required": ["mode", "failPolicy"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["transcript_only", "optional_web"] },
        "failPolicy": { "type": "string", "enum": ["graceful_fallback", "fail_fast"] },
        "maxWebSourcesPerTurn": { "type": "number", "minimum": 1 }
      }
    }
  }
}
